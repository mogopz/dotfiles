{
  "edit_predictions": {
    "allow_data_collection": "no",
  },
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "mode": "agent",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "agent": {
    "show_turn_stats": true,
    "sidebar_side": "right",
    "dock": "right",
  },
  "git_panel": {
    "dock": "left",
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "docker-compose": true,
    "dockerfile": true,
    "editorconfig": true,
    "git-firefly": true,
    "lua": true,
    "make": true,
    "sql": true,
    "terraform": true,
    "toml": true,
  },
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 12.0,
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "cursor_blink": false,
  "icon_theme": "Catppuccin Mocha",
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "terminal": {
    "option_as_meta": true,
    "font_family": "JetBrainsMono Nerd Font Mono",
    "font_size": 13.0,
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
  },
}
